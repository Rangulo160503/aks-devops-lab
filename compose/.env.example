# Optional override file for `docker compose --env-file compose/.env`.
# Most values in compose/docker-compose.yml are already set inline; this file
# exists so secrets and overrides have a clear, ignored home.

POSTGRES_USER=proyectoml
POSTGRES_PASSWORD=proyectoml
POSTGRES_DB=proyectoml

SECRET_KEY=dev-secret-change-me
APP_COLOR=blue
APP_ENV=local
