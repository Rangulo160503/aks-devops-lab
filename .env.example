# Top-level .env example. Used by tooling that loads the workspace .env at the
# repo root (e.g. some IDEs). Per-component examples live next to each
# component:
#   compose/.env.example         (docker-compose)
#   app/backend/README.md        (backend env vars)
#   app/frontend/README.md       (frontend env vars)

# Backend
APP_NAME=proyecto-ml-api
APP_ENV=local
APP_COLOR=blue
SECRET_KEY=dev-secret-change-me
DATABASE_URL=postgresql+psycopg://proyectoml:proyectoml@localhost:5432/proyectoml
LOG_LEVEL=INFO

# Frontend (build-time)
VITE_API_BASE=/api
VITE_APP_VERSION=dev
