# infra/terraform/envs/dev.backend.hcl.example
#
# Template for the azurerm backend-config used by the DEV environment.
# Do not edit this file directly. Two ways to produce the real
# `dev.backend.hcl`:
#
#   1. Terraform bootstrap (canonical):
#        cd infra/bootstrap
#        terraform output -raw backend_config_dev > ../terraform/envs/dev.backend.hcl
#
#   2. az-CLI bootstrap (fallback):
#        scripts/tf-bootstrap.sh         # writes envs/dev.backend.hcl directly
#        scripts/tf-bootstrap.ps1        # PowerShell variant
#
# Then:
#        cd infra/terraform
#        terraform init -backend-config=envs/dev.backend.hcl

resource_group_name  = "pml-tfstate-rg"
storage_account_name = "pmltfstate<RANDOM>"
container_name       = "tfstate"
key                  = "dev.tfstate"
use_azuread_auth     = true
