# infra/terraform/envs/prod.backend.hcl.example
#
# Template for the azurerm backend-config used by the PROD environment.
# See dev.backend.hcl.example for how to materialize the real file.

resource_group_name  = "pml-tfstate-rg"
storage_account_name = "pmltfstate<RANDOM>"
container_name       = "tfstate"
key                  = "prod.tfstate"
use_azuread_auth     = true
